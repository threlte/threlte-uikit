{
  "name": "threlte-uikit",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michealparks/threlte-uikit.git"
  },
  "bugs": {
    "url": "https://github.com/michealparks/threlte-uikit/issues"
  },
  "homepage": "https://github.com/michealparks/threlte-uikit#readme",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest --browser.name=chromium --browser.headless",
    "prettier": "prettier --check",
    "lint": "svelte-kit sync && prettier --check . && eslint .",
    "format": "prettier --write . && eslint . --fix",
    "release": "npm publish --provenance --access public && changeset tag"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./kit": {
      "types": "./dist/components/kit/index.d.ts",
      "svelte": "./dist/components/kit/index.js"
    },
    "./horizon": {
      "types": "./dist/components/horizon/index.d.ts",
      "svelte": "./dist/components/horizon/index.js"
    },
    "./lucide": {
      "types": "./dist/components/lucide/index.d.ts",
      "svelte": "./dist/components/lucide/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "dependencies": {
    "@pmndrs/uikit": "^1.0.64",
    "@pmndrs/uikit-default": "^1.0.64",
    "@pmndrs/uikit-horizon": "^1.0.64",
    "@pmndrs/uikit-lucide": "^1.0.64",
    "@preact/signals-core": "^1.14.1"
  },
  "peerDependencies": {
    "@threlte/core": ">=8",
    "svelte": ">=5",
    "three": ">=0.160"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@preact/signals-core": "^1.14.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@threlte/core": "^8.5.5",
    "@threlte/extras": "^9.14.0",
    "@threlte/test": "^1.0.0",
    "@types/eslint": "^9.6.1",
    "@types/three": "^0.183.1",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "camera-controls": "^3.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-svelte": "^3.16.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.3.18",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "three": "^0.183.2",
    "three-inspect": "^0.7.2",
    "tslib": "^2.8.1",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
