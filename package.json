{
  "name": "threlte-uikit",
  "version": "1.2.1",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michealparks/threlte-uikit.git"
  },
  "bugs": {
    "url": "https://github.com/michealparks/threlte-uikit/issues"
  },
  "homepage": "https://github.com/michealparks/threlte-uikit#readme",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest --browser.name=chromium --browser.headless",
    "prettier": "prettier --check",
    "lint": "svelte-kit sync && prettier --check . && eslint .",
    "format": "prettier --write .",
    "release": "changeset publish"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "dependencies": {
    "@pmndrs/uikit": "^1.0.0",
    "@preact/signals-core": "^1.11.0"
  },
  "peerDependencies": {
    "@threlte/core": ">=8",
    "svelte": ">=5",
    "three": ">=0.160"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.33.0",
    "@preact/signals-core": "^1.11.0",
    "@sveltejs/adapter-auto": "^6.1.0",
    "@sveltejs/kit": "^2.31.1",
    "@sveltejs/package": "^2.4.1",
    "@sveltejs/vite-plugin-svelte": "^6.1.2",
    "@threlte/core": "^8.1.4",
    "@threlte/extras": "^9.4.5",
    "@threlte/test": "^1.0.0",
    "@types/eslint": "^9.6.1",
    "@types/three": "^0.179.0",
    "@vitest/browser": "^3.2.4",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^16.3.0",
    "playwright": "^1.54.2",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "publint": "^0.3.12",
    "svelte": "^5.38.2",
    "svelte-check": "^4.3.1",
    "three": "^0.179.1",
    "three-inspect": "^0.7.2",
    "tslib": "^2.8.1",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  }
}
